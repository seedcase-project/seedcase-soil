{
  "name": "test-package",
  "title": "Test Package",
  "description": "A simple datapackage for testing purposes",
  "version": "1.0.0",
  "licenses": [
    {
      "name": "MIT"
    }
  ],
  "resources": [
    {
      "name": "data",
      "path": "data.csv",
      "schema": {
        "fields": [
          {
            "name": "id",
